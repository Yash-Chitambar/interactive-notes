# Copy this file to .env.local and fill in your API keys
# NEVER commit .env.local to git

# Google Gemini (required — get from https://ai.dev)
GEMINI_API_KEY=your_gemini_api_key_here

# WolframAlpha (Person 5 — get from https://developer.wolframalpha.com)
WOLFRAM_APP_ID=your_wolfram_app_id_here

# BrowserBase (Person 5 — get from https://www.browserbase.com)
BROWSERBASE_API_KEY=your_browserbase_api_key_here

# AfterQuery (Person 5)
AFTERQUERY_API_KEY=your_afterquery_api_key_here

# ChromaDB backend URL (Person 1 — localhost during hackathon)
CHROMA_BACKEND_URL=http://localhost:8001

# WebSocket relay URL (Person 2 — localhost during hackathon)
NEXT_PUBLIC_WS_RELAY_URL=ws://localhost:8080
